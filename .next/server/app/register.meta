{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(site)/layout,_N_T_/(site)/register/layout,_N_T_/(site)/register/page,_N_T_/register"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHNpdGUp/register/__PAGE__",
    "/!KHNpdGUp/register",
    "/!KHNpdGUp",
    "/_index",
    "/_head"
  ]
}