    "/api/auth/logout": {},
    "/api/auth/me": {},
    "/api/auth/profile": {},
    "/api/auth/register": {},
    "/api/auth/reset-password": {},
    "/api/blogs": {},
    "/api/blogs/[slug]": {},
    "/api/checkout/create-order": {},
